# ─── Required ────────────────────────────────────────────
BOT_TOKEN=your-telegram-bot-token-from-botfather
WEBHOOK_URL=https://your-app-name.onrender.com

# ─── Instagram (optional — needed for stories & private) ─
INSTA_USERNAME=
INSTA_PASSWORD=

# ─── Optional ────────────────────────────────────────────
# Comma-separated Telegram user IDs.  Leave empty for public access.
ALLOWED_USERS=
# Maximum posts to download from a single profile (default 50)
MAX_PROFILE_POSTS=50
